#include <iostream>
#include <cuda_runtime.h>
#include <chrono>

using namespace std;
using namespace chrono;

const int BLOCK_SIZE = 256;
const size_t N = 100000000;

__global__ void sumKernel(const float* d_arr, float* d_sum, size_t n) {
    extern __shared__ float sdata[];
    int tid = threadIdx.x;
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    
    sdata[tid] = (idx < n) ? d_arr[idx] : 0.0f;
    __syncthreads();
    
    for (int s = blockDim.x / 2; s > 0; s >>= 1) {
        if (tid < s) {
            sdata[tid] += sdata[tid + s];
        }
        __syncthreads();
    }
    
    if (tid == 0) {
        atomicAdd(d_sum, sdata[0]);
    }
}

int main() {
    size_t bytes = N * sizeof(float);
    float* h_arr = new float[N];
    
    srand(time(nullptr));
    for (size_t i = 0; i < N; ++i) {
        h_arr[i] = static_cast<float>(rand()) / RAND_MAX * 100.0f;
    }
    
    float *d_arr, *d_sum;
    cudaMalloc(&d_arr, bytes);
    cudaMalloc(&d_sum, sizeof(float));
    
    cudaMemcpy(d_arr, h_arr, bytes, cudaMemcpyHostToDevice);
    cudaMemset(d_sum, 0, sizeof(float));
    
    int threadsPerBlock = BLOCK_SIZE;
    int blocksPerGrid = (N + threadsPerBlock - 1) / threadsPerBlock;
    size_t sharedMemSize = threadsPerBlock * sizeof(float);
    
    cudaEvent_t start, stop;
    cudaEventCreate(&start);
    cudaEventCreate(&stop);
    
    cudaEventRecord(start);
    sumKernel<<<blocksPerGrid, threadsPerBlock, sharedMemSize>>>(d_arr, d_sum, N);
    cudaEventRecord(stop);
    cudaEventSynchronize(stop);
    
    float milliseconds = 0;
    cudaEventElapsedTime(&milliseconds, start, stop);
    
    float h_sum;
    cudaMemcpy(&h_sum, d_sum, sizeof(float), cudaMemcpyDeviceToHost);
    
    cout << "Sum: " << h_sum << endl;
    cout << "Time: " << milliseconds / 1000.0 << " seconds" << endl;
    
    cudaFree(d_arr);
    cudaFree(d_sum);
    delete[] h_arr;
    
    return 0;
}
